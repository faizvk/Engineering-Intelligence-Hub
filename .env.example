# .env.example — copy to .env and fill in.   cp .env.example .env
# Never commit .env. The two API keys are required; the app refuses to boot without them.

# --- Anthropic (generation + routing) ---
ANTHROPIC_API_KEY=sk-ant-...
MODEL_WORKHORSE=claude-sonnet-4-6
MODEL_HARD=claude-opus-4-8
MODEL_ROUTER=claude-haiku-4-5

# --- Voyage (embeddings + reranking) — VERIFY current model names at docs.voyageai.com ---
VOYAGE_API_KEY=pa-...
EMBED_MODEL=voyage-3.5
EMBED_MODEL_CODE=voyage-code-3
RERANK_MODEL=rerank-2.5
EMBED_DIM=1024

# --- Postgres (matches docker-compose.yml). Note the +psycopg driver suffix. ---
# Host shell uses localhost; the backend container uses host "db" (compose overrides it).
DATABASE_URL=postgresql+psycopg://eih:eih@localhost:5432/eih
# Plain psycopg DSN (no SQLAlchemy +driver suffix) for the raw full-text retriever.
DATABASE_URL_RAW=postgresql://eih:eih@localhost:5432/eih

# --- LangSmith (optional tracing) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=eih-dev

# --- Frontend CORS (comma-separated origins the API accepts) ---
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Auth & abuse prevention (auth off by default for the open demo) ---
AUTH_ENABLED=false
JWT_PUBLIC_KEY=
JWT_AUDIENCE=eih
RATE_LIMIT_PER_MINUTE=20
DAILY_SPEND_CAP_USD=5.0
